{
  "$schema": "https://turborepo.org/schema.json",
  "tasks": {
    // Global lint task
    "lint:all": {
      "cache": false
    },
    // Backend (API) build
    "@coursehub/backend#build": {
      "dependsOn": [],
      "outputs": ["build/**/*"]
    },
    // Prisma client generation
    "@coursehub/backend#db:generate": {
      "dependsOn": ["@coursehub/backend#build"],
      "cache": true,
      "outputs": ["prisma/generated"],
      "persistent": false
    },
    // API docs generation (openapi.json)
    "@coursehub/backend#api:gen": {
      "dependsOn": ["@coursehub/backend#build"],
      "outputs": ["../../openapi.json"]
    },
    // SDK generation from OpenAPI spec
    "@coursehub/sdk#gen:sdk": {
      "dependsOn": ["@coursehub/backend#api:gen"],
      "outputs": ["src/**/*"]
    },
    // SDK build
    "@coursehub/sdk#build": {
      "dependsOn": ["@coursehub/sdk#gen:sdk"],
      "outputs": ["build/**/*"]
    },
    // Frontend
    "@coursehub/client#build": {
      "dependsOn": ["@coursehub/sdk#build"],
      "outputs": ["dist/**/*"]
    },
    // Bundle frontend static assets to backend public dir
    "@coursehub/coursehub#bundle:static": {
      "dependsOn": ["@coursehub/client#build", "@coursehub/backend#build"],
      "outputs": ["public/**"],
      "cache": false
    },
    // Build backend Docker image
    "docker:build": {
      "dependsOn": ["@coursehub/client#build"],
      "outputs": []
    },
    // General build task
    "build": {
      "dependsOn": ["^build", "lint:all", "@coursehub/coursehub#bundle:static", "docker:build"],
      "outputs": ["build/**", "dist/**", "prisma/generated/**", "public/**"]
    },
    // Global test task
    "test": {
    "dependsOn": ["build"],
    "outputs": [],
    "cache": false
    }
  },
  "globalDependencies": [".env", "tsconfig.base.json"]
}
