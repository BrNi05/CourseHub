    "start:debug": "pnpm prebuild && nest start --debug --watch",
    "start:prod": "node build/main.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "prisma generate --no-hints",
    "db:seed": "prisma db seed",
    "db:view": "prisma studio",
    "api:gen": "ts-node --project tsconfig.openapi.json openapi.generate.ts",
    "docker:prune": "docker system prune -a -f"
  },
