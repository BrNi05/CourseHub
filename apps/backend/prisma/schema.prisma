// Schema docs: https://pris.ly/d/prisma-schema

// Generate the Prisma Client: pnpm prisma generate
// To create the tables: pnpm prisma migrate dev --name ...
//! Prod migrations are done by hand!!!

generator client {
  provider = "prisma-client"
  output = "../src/prisma/generated/client"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x", "debian-openssl-3.0.x"]
  compilerBuild = "fast" // https://github.com/prisma/prisma/releases/tag/7.3.0
}

datasource db {
  provider = "postgresql"
}

// University
// Assume name is not unique (yet it is)
// A university has many faculties and users
model University {
  id                 String    @id @default(uuid())
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @default(now()) @updatedAt

  name               String    @unique
  abbrevName         String    @unique

  faculties          Faculty[]
}

// Faculty
// Name is not neccessarily unique
// A faculty belongs to a university and has many courses
model Faculty {
  id           String     @id @default(uuid())
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @default(now()) @updatedAt

  name         String
  abbrevName   String

  universityId String
  university   University @relation(fields: [universityId], references: [id], onDelete: Cascade)

  courses      Course[] // A faculty can have multiple courses
  packages     CoursePackage[] // A faculty can have multiple course packages

  @@unique([name, universityId]) // A faculty name is unique within a university
  @@unique([abbrevName, universityId]) // A faculty abbrev name is unique within a university
  @@index([universityId]) // Fast lookup when filtering faculties by universityId
}

// Course
// Name and code are not necessarily unique
// A course belongs to a faculty and can be pinned by many users
model Course {
  id                  String          @id @default(uuid())
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @default(now()) @updatedAt

  name                String
  code                String          @unique // Course code is globally unique

  facultyId           String
  faculty             Faculty         @relation(fields: [facultyId], references: [id], onDelete: Cascade)

  pinnedBy            User[]          @relation("UserPinnedCourses")

  coursePageUrl       String          @default("") // official (lecturer) page
  courseTadUrl        String          @default("") // TAD (uni) page
  courseMoodleUrl     String          @default("") // Moodle page
  courseSubmissionUrl String          @default("") // For homework, etc submission
  courseTeamsUrl      String          @default("") // Microsoft Teams page
  courseExtraUrl      String          @default("") // Additional course page (Wiki, Github)

  packages            CoursePackage[] @relation("PackageCourses") // A course can be in multiple packages

  // CourseHub assumes course codes are unique, globally. This is made sure like so:
  // Course code at BME: BMEVIIIAB12 --> BMEVIIIAB12
  // Course code at ELTE: EGTI24MN105 --> ELTEGTI24MN105
  // Rule: append university abbreviated name if not already

  //@@unique([name, facultyId]) // A course name is unique within a faculty
  //@@unique([code, facultyId]) // A course code is unique within a faculty
  @@index([facultyId]) // Fast lookup when filtering courses by facultyId
}

// SuggestedCourse
// A course suggested by a user, but not yet verified by admins
// On accept, it is deleted and a new Course (and faculty, and university) is created with the same data
model SuggestedCourse {
  id                  String   @id @default(uuid())
  createdAt           DateTime @default(now())
  updatedAt           DateTime @default(now()) @updatedAt
  userEmail           String

  uniName             String
  uniAbbrevName       String

  facultyName         String
  facultyAbbrevName   String

  courseName          String
  courseCode          String   @unique      // only one suggestion per course at a time

  coursePageUrl       String   @default("") // official (lecturer) page
  courseTadUrl        String   @default("") // TAD (uni) page
  courseMoodleUrl     String   @default("") // Moodle page
  courseSubmissionUrl String   @default("") // For homework, etc submission
  courseTeamsUrl      String   @default("") // Microsoft Teams page
  courseExtraUrl      String   @default("") // Additional course page (Wiki, Github)
}

// User
// A user can pin many courses
// A user is authenticated with Google OAuth2
model User {
  id            String     @id @default(uuid())
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @default(now()) @updatedAt

  googleId      String     @unique
  googleEmail   String     @unique

  // Possible other roles in the future (like contributor (reduced rights) or so)
  isAdmin       Boolean    @default(false)

  pinnedCourses Course[]   @relation("UserPinnedCourses") // A user can pin multiple courses
  ownedPackages CoursePackage[] // A user can own multiple course packages

  clientPings   ClientPing[]
}

// CoursePackage
// A collection of courses, created by a user, that can be shared with others via a link
model CoursePackage {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  name        String
  description String   @default("")

  ownerId     String
  owner       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade) // owned by a user

  facultyId   String
  faculty     Faculty  @relation(fields: [facultyId], references: [id], onDelete: Cascade) // belongs to a faculty (and a university)

  isPermanent Boolean  @default(false)
  lastUsedAt  DateTime @default(now())

  courses     Course[] @relation("PackageCourses")

  @@index([ownerId]) // Fast lookup when filtering packages by ownerId (show my endpoint)
  @@index([facultyId]) // Fast lookup when filtering packages by facultyId (search endpoint)
  @@index([isPermanent, lastUsedAt]) // Fast lookup of non-permanent packages sorted by last used date for cleanup
}

// ClientPing
// Daily ping from the client to track usage statistics
model ClientPing {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  userId    String?   // Internal user ID, not the Google ID
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  date      DateTime // normalized UTC start-of-day

  platform  ClientPlatform
  version   String

  @@unique([userId, date, platform]) // One ping per user per day per platform
  @@index([date]) // Fast lookup of pings by date for statistics
  @@index([platform]) // Fast lookup of pings by platform for statistics
}

// ClientPlatform
// Separate desktop releases for better usage statistics and error reporting
enum ClientPlatform {
  windows
  linux
  macos
  android
  ios
}
