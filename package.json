{
  "name": "@coursehub/coursehub",
  "version": "1.0.0",
  "description": "",
  "scripts": {
    "lint:all": "eslint . --ext .ts,.js,.vue --cache --max-warnings=0",
    "build:all": "turbo run build",
    "test": "turbo run test",
    "refresh:sdk": "pnpm --filter ./apps/backend api:gen && pnpm --filter ./packages/sdk gen:sdk",
    "bundle:static": "node ./dev-tools/copy-client-to-backend.mjs",
    "docker:build": "docker build -t coursehub -f Dockerfile .",
    "clear:all": "pnpm -r exec rimraf node_modules .build build .turbo .eslintcache openapi.json && rm -rf node_modules",
    "update:node": "node ./dev-tools/node-updater.js",
    "update:deps": "pnpm update && pnpm dedupe",
    "safe": "git config core.hooksPath .husky",
    "unsafe": "git config --unset core.hooksPath"
  },
  "keywords": [],
  "author": "BrNi05",
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.30.3+sha512.c961d1e0a2d8e354ecaa5166b822516668b7f44cb5bd95122d590dd81922f606f5473b6d23ec4a5be05e7fcd18e8488d47d978bbe981872f1145d06e9a740017",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@hey-api/client-axios": "^0.9.1",
    "@hey-api/openapi-ts": "^0.94.0",
    "@types/node": "^25.4.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@typescript-eslint/utils": "^8.57.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "turbo": "^2.8.16",
    "typescript": "^5.9.3",
    "vue-eslint-parser": "^10.4.0"
  }
}
