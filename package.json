{
  "name": "@coursehub/coursehub",
  "version": "1.7.5",
  "description": "Egyetemi tárgyak, egyszerűen.",
  "keywords": [],
  "author": "BrNi05",
  "license": "Apache-2.0",
  "private": true,
  "packageManager": "pnpm@11.5.0+sha512.dbfcc4f81cf48597afd4bc391ffdf12c11f1a9fb83a395bfa6b0a2d9cc2fd8ffebafdb1ccbd529632153f793904c2615b7f09fe1a345473fd1c35845172a8eb1",
  "scripts": {
    "lint:all": "eslint . --ext .ts,.js,.vue --cache --max-warnings=0",
    "build:all": "turbo run build",
    "test": "turbo run test",
    "refresh:sdk": "pnpm --filter ./apps/backend api:gen && pnpm --filter ./packages/sdk gen:sdk",
    "bundle:static": "node ./dev-tools/copy-client-to-backend.mjs",
    "docker:build": "docker build -t coursehub -f Dockerfile .",
    "scan:image": "trivy image --scanners vuln,secret --pkg-types library --severity HIGH,CRITICAL --ignore-unfixed -o trivy-image-report.txt coursehub:latest && code -r trivy-image-report.txt",
    "clear:all": "pnpm -r exec rimraf node_modules .build build .turbo .eslintcache openapi.json && rm -rf node_modules",
    "update:node": "node ./dev-tools/node-updater.mjs",
    "update:pnpm": "node ./dev-tools/pnpm-updater.mjs",
    "update:version": "node ./dev-tools/version-bumper.mjs",
    "update:deps": "pnpm -r update && pnpm dedupe",
    "safe": "git config core.hooksPath .husky",
    "unsafe": "git config --unset core.hooksPath"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@hey-api/openapi-ts": "^0.97.3",
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "@typescript-eslint/utils": "^8.60.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-vue": "^10.9.1",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "turbo": "^2.9.16",
    "typescript": "^6.0.3",
    "vue-eslint-parser": "^10.4.0"
  }
}
