# Superuser for the test database
POSTGRES_USER=postgres

# Password for the superuser
POSTGRES_PASSWORD=

# Name of the default database to be created
POSTGRES_DB=postgres

# External port to map to the PostgreSQL default port (5432)
POSTGRES_PORT=

# Redis server host (IP address or hostname)
REDIS_HOST=

# Password for the Redis instance
REDIS_PASSWORD=

# External port to map to the Redis default port (6379)
# Should match the port in the REDIS_URL above
REDIS_PORT=